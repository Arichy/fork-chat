# Path to the JSON config file consumed by the `config` crate. Defaults to
# `./config.json` if unset. See `config.example.json` for the schema.
FORK_CHAT_CONFIG=./config.json

# The only value that commonly travels through env. Any other field can be
# overridden via `FORK_CHAT_<FIELD>` with `__` as the nesting separator, e.g.
# `FORK_CHAT_SERVER_ADDR=127.0.0.1:3000`. Leave unset to take the JSON value.
# DATABASE_URL is read from the JSON file's `database_url`; you only need this
# here if you want env to win or if `sqlx` CLI needs it.
DATABASE_URL=postgres://postgres:password@localhost/fork-chat

# Values referenced by config.json placeholders such as
# `"api_key": "${DEEPSEEK_API_KEY}"`.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
