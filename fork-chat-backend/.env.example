# PostgreSQL connection string used by sqlx
DATABASE_URL=postgres://postgres:password@localhost/fork-chat

# OpenAI-compatible API key (OpenAI, Groq, etc.)
OPENAI_API_KEY=sk-your-key-here

# Optional: custom OpenAI-compatible base URL
# e.g. https://api.openai.com/v1  (default)
#      https://api.groq.com/openai/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Axum bind address
SERVER_ADDR=0.0.0.0:3000

# Comma-separated list of model IDs exposed to the frontend
MODELS=gpt-4o-mini
